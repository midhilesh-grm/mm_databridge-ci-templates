  "additionalProperties": false,
  "description": "Resource configuration for database tables.\n\nFile location: configs/resources/{source_name}/{resource_name}.yaml\n\nSupports TWO configuration formats:\n\n1. **Detailed Format** (original): Use `tables` field for full control\n   over each table's configuration. Best for complex requirements.\n\n2. **Grouped Format** (simplified): Use `defaults` + grouped sections\n   (`snapshot_tables`, `incremental_tables`, `merge_tables`) for bulk\n   configuration of 50+ tables with shared settings.\n\n**Table Selection Policy (SECURITY):**\n\nExplicit table list is REQUIRED by default. This framework does NOT allow\n\"reflect all tables\" behavior to prevent accidental ingestion of:\n    - Temporary tables (TMP_*, STAGING_*)\n    - Backup tables (*_BACKUP, *_OLD)\n    - Test data (TEST_*, DEV_*)\n    - System tables (SYS_*, LOG_*)\n\n**Discovery Mode (Opt-In Only):**\n\nIf you need \"all tables\" behavior, explicitly enable `discovery_mode: true`\nand provide `exclude_patterns` for safety. This requires deliberate opt-in\nand forces you to think about exclusions.\n\nNote: The subdirectory name MUST match source.name from the source config.\nYou can use EITHER format, or mix them (grouped + tables for edge cases).\n\nExample (Grouped Format):\n    resource:\n      source_ref: \"oracle_sales_de\"\n      defaults:\n        schema: \"SALES\"\n        add_load_date: true\n      snapshot_tables:\n        - name: \"PRODUCT_CATALOG\"\n        - name: \"REGIONS\"\n      incremental_tables:\n        - name: \"CUSTOMERS\"\n          cursor_field: \"UPDATED_AT\"\n        - name: \"ORDERS\"\n          cursor_field: \"ORDER_DATE\"\n\nExample (Discovery Mode):\n    resource:\n      source_ref: \"oracle_sales_de\"\n      discovery_mode: true\n      schema: \"SALES\"\n      exclude_patterns:\n        - \"^TMP_.*\"\n        - \"^STAGING_.*\"\n        - \".*_BACKUP$\"\n        - \".*_OLD$\"",
  "properties": {
    "defaults": {
      "anyOf": [
        {
          "$ref": "#/$defs/TableDefaultsConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Shared defaults for all grouped table sections"
    },
    "discovery_mode": {
      "default": false,
      "description": "Enable discovery mode to reflect all tables in schema. REQUIRES exclude_patterns for safety. Use with caution.",
      "title": "Discovery Mode",
      "type": "boolean"
    },
    "exclude_patterns": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Regex patterns to exclude tables in discovery mode. Example: ['^TMP_.*', '.*_BACKUP$', '^TEST_.*']",
      "title": "Exclude Patterns"
    },
    "include_views": {
      "default": false,
      "description": "Include views in discovery mode (default: false)",
      "title": "Include Views",
      "type": "boolean"
    },
    "incremental_tables": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/IncrementalTableEntry"
          },
          "type": "array"
        },
        {
          "$ref": "#/$defs/IncrementalGroupConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Incremental tables (mode=incremental, write_disposition=append)",
      "title": "Incremental Tables"
    },
    "merge_tables": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/MergeTableEntry"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Merge tables (write_disposition=merge, for Reverse ETL)",
      "title": "Merge Tables"
    },
    "parallel_extraction": {
      "$ref": "#/$defs/ParallelExtractionConfig",
      "description": "Parallel extraction settings"
    },
    "snapshot_tables": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/SnapshotTableEntry"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Snapshot tables (mode=snapshot, write_disposition=replace)",
      "title": "Snapshot Tables"
    },
    "source_ref": {
      "description": "Reference to source config name",
      "title": "Source Ref",
      "type": "string"
    },
    "tables": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/TableResourceConfig"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Detailed table configs (original format, full control)",
      "title": "Tables"
    },
    "type": {
      "const": "tables",
      "default": "tables",
      "description": "Resource type",
      "title": "Type",
      "type": "string"
    }
  },
  "required": [
    "source_ref"
  ],
  "title": "ResourceConfig",
  "type": "object"

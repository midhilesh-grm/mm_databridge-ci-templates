{
  "$defs": {
    "ClusterConfig": {
      "additionalProperties": false,
      "description": "Table clustering configuration.\n\nDestination-Specific Behavior:\n    - Databricks: Uses Liquid Clustering (not ZORDER). Use \"AUTO\" for automatic.\n                 Cannot use with partition on same table.\n    - BigQuery: Uses cluster_by, max 4 fields enforced by BigQuery.\n    - Oracle/MSSQL: Not supported (validation will reject).\n\nNote: Field count validation is done at runtime based on destination type.",
      "properties": {
        "fields": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "const": "AUTO",
              "type": "string"
            }
          ],
          "description": "Fields to cluster by, or 'AUTO' for Databricks auto liquid clustering",
          "title": "Fields"
        }
      },
      "required": [
        "fields"
      ],
      "title": "ClusterConfig",
      "type": "object"
    },
    "DQCheckCustomSql": {
      "additionalProperties": false,
      "description": "Custom SQL check configuration.",
      "properties": {
        "max_failures": {
          "default": 0,
          "description": "Maximum allowed failures (0 = no failures allowed)",
          "minimum": 0,
          "title": "Max Failures",
          "type": "integer"
        },
        "query": {
          "description": "SQL query returning failure count (use {table} placeholder)",
          "title": "Query",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/DQSeverity",
          "default": "error",
          "description": "Severity level if check fails"
        },
        "type": {
          "const": "custom_sql",
          "default": "custom_sql",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "query"
      ],
      "title": "DQCheckCustomSql",
      "type": "object"
    },
    "DQCheckFreshness": {
      "additionalProperties": false,
      "description": "Data freshness check configuration.",
      "properties": {
        "column": {
          "description": "Timestamp column to check for freshness",
          "title": "Column",
          "type": "string"
        },
        "max_age_hours": {
          "description": "Maximum allowed age in hours",
          "minimum": 1,
          "title": "Max Age Hours",
          "type": "integer"
        },
        "severity": {
          "$ref": "#/$defs/DQSeverity",
          "default": "error",
          "description": "Severity level if check fails"
        },
        "type": {
          "const": "freshness",
          "default": "freshness",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "column",
        "max_age_hours"
      ],
      "title": "DQCheckFreshness",
      "type": "object"
    },
    "DQCheckNotNull": {
      "additionalProperties": false,
      "description": "Not null check configuration.",
      "properties": {
        "columns": {
          "description": "Columns to check for null values",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Columns",
          "type": "array"
        },
        "severity": {
          "$ref": "#/$defs/DQSeverity",
          "default": "error",
          "description": "Severity level if check fails"
        },
        "type": {
          "const": "not_null",
          "default": "not_null",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "columns"
      ],
      "title": "DQCheckNotNull",
      "type": "object"
    },
    "DQCheckRange": {
      "additionalProperties": false,
      "description": "Value range check configuration.",
      "properties": {
        "column": {
          "description": "Column to check for value range",
          "title": "Column",
          "type": "string"
        },
        "max_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum allowed value (inclusive)",
          "title": "Max Value"
        },
        "min_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Minimum allowed value (inclusive)",
          "title": "Min Value"
        },
        "severity": {
          "$ref": "#/$defs/DQSeverity",
          "default": "error",
          "description": "Severity level if check fails"
        },
        "type": {
          "const": "range",
          "default": "range",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "column"
      ],
      "title": "DQCheckRange",
      "type": "object"
    },
    "DQCheckRegex": {
      "additionalProperties": false,
      "description": "Regex pattern check configuration.",
      "properties": {
        "column": {
          "description": "Column to validate against pattern",
          "title": "Column",
          "type": "string"
        },
        "pattern": {
          "description": "Regular expression pattern",
          "title": "Pattern",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/DQSeverity",
          "default": "warning",
          "description": "Severity level if check fails"
        },
        "type": {
          "const": "regex",
          "default": "regex",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "column",
        "pattern"
      ],
      "title": "DQCheckRegex",
      "type": "object"
    },
    "DQCheckUnique": {
      "additionalProperties": false,
      "description": "Uniqueness check configuration.",
      "properties": {
        "columns": {
          "description": "Columns to check for uniqueness (compound key if multiple)",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Columns",
          "type": "array"
        },
        "severity": {
          "$ref": "#/$defs/DQSeverity",
          "default": "error",
          "description": "Severity level if check fails"
        },
        "type": {
          "const": "unique",
          "default": "unique",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "columns"
      ],
      "title": "DQCheckUnique",
      "type": "object"
    },
    "DQSeverity": {
      "description": "Data quality check severity levels.",
      "enum": [
        "error",
        "warning"
      ],
      "title": "DQSeverity",
      "type": "string"
    },
    "DataQualityConfig": {
      "additionalProperties": false,
      "description": "Data quality configuration for a table or pipeline.",
      "properties": {
        "checks": {
          "description": "List of data quality checks to run",
          "items": {
            "discriminator": {
              "mapping": {
                "custom_sql": "#/$defs/DQCheckCustomSql",
                "freshness": "#/$defs/DQCheckFreshness",
                "not_null": "#/$defs/DQCheckNotNull",
                "range": "#/$defs/DQCheckRange",
                "regex": "#/$defs/DQCheckRegex",
                "unique": "#/$defs/DQCheckUnique"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/DQCheckNotNull"
              },
              {
                "$ref": "#/$defs/DQCheckUnique"
              },
              {
                "$ref": "#/$defs/DQCheckRegex"
              },
              {
                "$ref": "#/$defs/DQCheckRange"
              },
              {
                "$ref": "#/$defs/DQCheckFreshness"
              },
              {
                "$ref": "#/$defs/DQCheckCustomSql"
              }
            ]
          },
          "title": "Checks",
          "type": "array"
        },
        "enabled": {
          "default": true,
          "description": "Enable data quality checks",
          "title": "Enabled",
          "type": "boolean"
        },
        "fail_on_error": {
          "default": false,
          "description": "Fail pipeline if any DQ check fails with ERROR severity",
          "title": "Fail On Error",
          "type": "boolean"
        }
      },
      "title": "DataQualityConfig",
      "type": "object"
    },
    "IncrementalGroupConfig": {
      "additionalProperties": false,
      "description": "Group configuration for incremental tables with shared cursor_field default.\n\nUse when multiple tables share the same cursor_field pattern.",
      "properties": {
        "default_cursor_field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Default cursor field for all tables in this group",
          "title": "Default Cursor Field"
        },
        "default_cursor_initial_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Default initial cursor value",
          "title": "Default Cursor Initial Value"
        },
        "tables": {
          "description": "List of incremental tables",
          "items": {
            "$ref": "#/$defs/IncrementalTableEntry"
          },
          "minItems": 1,
          "title": "Tables",
          "type": "array"
        }
      },
      "required": [
        "tables"
      ],
      "title": "IncrementalGroupConfig",
      "type": "object"
    },
    "IncrementalTableEntry": {
      "additionalProperties": false,
      "description": "Simplified entry for incremental (append) tables.\n\nIncremental tables use:\n    - mode: \"incremental\" (automatic)\n    - write_disposition: \"append\" (automatic, Bronze layer pattern)\n    - cursor_field: Required for tracking changes\n\nThis is the recommended pattern for Bronze layer ingestion.\nSupports custom_query for complex incremental extractions.",
      "properties": {
        "add_load_date": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Override default add_load_date setting",
          "title": "Add Load Date"
        },
        "cluster": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClusterConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Clustering configuration (overrides default)"
        },
        "columns": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Explicit column selection (None = all columns)",
          "title": "Columns"
        },
        "cursor_field": {
          "description": "Field for incremental cursor (required)",
          "title": "Cursor Field",
          "type": "string"
        },
        "cursor_initial_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Initial cursor value (string for dates, int for IDs, float for decimals)",
          "title": "Cursor Initial Value"
        },
        "custom_query": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Custom SQL query instead of table extraction",
          "title": "Custom Query"
        },
        "data_quality": {
          "anyOf": [
            {
              "$ref": "#/$defs/DataQualityConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Data quality configuration (overrides default)"
        },
        "name": {
          "description": "Table name",
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "partition": {
          "anyOf": [
            {
              "$ref": "#/$defs/PartitionConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Partitioning configuration (overrides default)"
        },
        "primary_key": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Primary key column(s) - optional for append, useful for dbt dedup",
          "title": "Primary Key"
        },
        "query_params": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Parameters for custom query",
          "title": "Query Params"
        },
        "schema": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Schema name (overrides default)",
          "title": "Schema"
        },
        "schema_contract": {
          "anyOf": [
            {
              "$ref": "#/$defs/SchemaContract"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Schema contract override for this table"
        }
      },
      "required": [
        "name",
        "cursor_field"
      ],
      "title": "IncrementalTableEntry",
      "type": "object"
    },
    "LoadMode": {
      "description": "Table loading mode.",
